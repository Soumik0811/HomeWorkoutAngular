{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "paths": {
      "@home-workout-tracker/workout-tracker-data": [
        "libs/workout-tracker-data/src/index.ts"
      ]
    },
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "useDefineForClassFields": false
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}

